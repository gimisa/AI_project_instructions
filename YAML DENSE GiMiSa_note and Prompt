    Log_Format: "EXCLUSIVELY Dense YAML (Shannon/Tufte logic)."
    Init_Stateless: "AI must request latest gimisa_note.yaml + previous log at start."
    Global_Dependency_Graph: "System 2 Thinking: Map impacts BEFORE architectural changes."
